{
  "name": "another-dynamic-highlights-plugin",
  "version": "1.2.9",
  "description": "Another Dynamic Highlights Plugin that highlights RegEx and word under cursor.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production --exclude=_Zeuch",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "RegEx",
    "highlights",
    "dynamic highlights",
    "writing tool",
    "avoid repetition"
  ],
  "author": "tine-schreibt",
  "license": "MIT",
  "dependencies": {
    "@simonwep/pickr": "1.9.1",
    "ajv": "^8.18.0",
    "lodash": "4.18.1",
    "lucide": "1.11.0",
    "regexp-match-indices": "1.0.2"
  },
  "devDependencies": {
    "@types/lodash": "4.17.13",
    "@types/node": "25.6.0",
    "@types/sortablejs": "1.15.9",
    "@typescript-eslint/eslint-plugin": "8.59.1",
    "@typescript-eslint/parser": "8.59.1",
    "builtin-modules": "5.1.0",
    "codemirror": "6.0.2",
    "esbuild": "0.28.0",
    "eslint": "10.2.1",
    "obsidian": "1.12.3",
    "stylelint": "17.9.1",
    "stylelint-config-standard": "40.0.0",
    "tslib": "2.8.1",
    "typescript": "6.0.3",
    "typescript-json-schema": "0.67.1"
  }
}
